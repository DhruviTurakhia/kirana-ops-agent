# Required at runtime. Never commit real secrets.
OPENAI_API_KEY=
TELEGRAM_BOT_TOKEN=

# The model is configurable so reviewers can use a model available to their API project.
OPENAI_MODEL=gpt-5.6-terra

# SECURITY: keep false for normal operation. When true, every Telegram user can
# spend API credits and change the shared store. Restart the bot after changing it.
ALLOW_ALL_TELEGRAM_USERS=false

# Comma-separated Telegram numeric user IDs allowed to operate the store when
# ALLOW_ALL_TELEGRAM_USERS=false. Usernames such as @shopowner are not accepted.
AUTHORIZED_TELEGRAM_USER_IDS=

DATABASE_PATH=./data/kirana.sqlite3
AGENT_SESSION_DATABASE_PATH=./data/agent_sessions.sqlite3
ARTIFACT_OUTPUT_DIR=./output
STORE_TIMEZONE=Asia/Kolkata
LOG_LEVEL=INFO
